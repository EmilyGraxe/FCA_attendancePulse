<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Dashboard — FCA</title>
<link rel="stylesheet" href="/css/bootstrap.min.css">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">
</head>
<body>
<div class="d-flex" id="wrapper">
  <%- include('partials/sidebar') %>
  <div id="page-content-wrapper">
    <%- include('partials/topnav', { title: 'Dashboard' }) %>
    <div class="container-fluid mt-4">
      <h4>Monthly Attendance Overview</h4>
      <div class="row my-4">
        <div class="col-md-6">
          <div class="card p-4"><canvas id="attendanceChart"></canvas></div>
        </div>
        <div class="col-md-6">
          <div class="row g-3">
            <div class="col-12">
              <div class="card p-3">
                <h5>Total Sessions This Month</h5>
                <p id="totalSessions" class="fs-3">0</p>
              </div>
            </div>
            <div class="col-12">
              <div class="card p-3">
                <h5>Total Students</h5>
                <p id="totalStudents" class="fs-3">0</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="/js/jquery.min.js"></script>
<script src="/js/bootstrap.bundle.min.js"></script>
<script src="/js/Chart.min.js"></script>
<script src="/js/dashboard.js"></script>
</body>
</html>
