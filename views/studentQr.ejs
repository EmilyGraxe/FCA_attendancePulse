<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Student QR — <%= student.name %></title>
  <link rel="stylesheet" href="/css/styles.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css">

  <style>
    body { text-align:center; font-family:sans-serif; padding:40px; }
    .qr-card { display:inline-block; padding:24px 32px; border:2px solid #ccc;
               border-radius:12px; background:#f4fdf7; }
    .qr-card h3 { color:rgb(17,74,17); margin-bottom:6px; }
    .asset-badge { display:inline-block; padding:3px 12px; border-radius:12px;
                   font-size:.82em; font-weight:600; margin:2px; }
    .asset-pc      { background:#cce5ff; color:#004085; }
    .asset-charger { background:#fff3cd; color:#856404; }
    .asset-headset { background:#e2d9f3; color:#4a235a; }
    button { padding:10px 24px; background:rgb(17,74,17); color:#fff;
             border:none; border-radius:6px; cursor:pointer; font-size:1em; margin-top:16px; }
    button:hover { background:#1a5c1a; }
    a.back { display:inline-block; margin-top:16px; color:rgb(17,74,17); font-weight:600; }
    @media print {
      body * { visibility:hidden; }
      .qr-card, .qr-card * { visibility:visible; }
      .qr-card { position:fixed; top:50%; left:50%; transform:translate(-50%,-50%); }
      button, a { display:none !important; }
    }
  </style>
</head>
<body>
  <h2>Student QR Code</h2>
  <div class="qr-card">
    <h3><%= student.name %></h3>
    <p><strong>Reg No:</strong> <%= student.reg_no %></p>
    <img src="<%= qrImage %>" alt="QR Code" width="200">
    <div style="margin-top:12px;">
      <% if (student.pc_asset)      { %><span class="asset-badge asset-pc"><i class="fa-solid fa-laptop"></i> <%= student.pc_asset %></span><% } %>
      <% if (student.charger_asset) { %><span class="asset-badge asset-charger"> <span class="fa-solid fa-battery-full"></span> <%= student.charger_asset %></span><% } %>
      <% if (student.headset_asset) { %><span class="asset-badge asset-headset"><i class="fa-solid fa-headset"></i> <%= student.headset_asset %></span><% } %>
    </div>
  </div>
  <br>
  <button id="printBtn"><i class="fa-solid fa-print me-2"></i> Print QR</button><br>
  <a href="/api/auth/students" class="back">← Back to Students</a>
  <script src="/js/studentQr.js"></script>
</body>
</html>
